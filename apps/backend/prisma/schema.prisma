generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String
  slug        String    @unique
  description String?
  imageUrl    String?
  products    Product[]
}

model Product {
  id             Int              @id @default(autoincrement())
  name           String
  description    String
  price          Float
  tags           String?
  images         String
  categoryId     Int
  materialCare   String?
  shippingReturn String?
  sizeChart      String?          // JSON: [{size, height, weight, bust, waist}]
  isFlashSale    Boolean          @default(false)
  flashSalePrice Float?
  flashSaleDiscount Int?
  soldCount      Int              @default(0)
  likeCount      Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @default(now()) @updatedAt
  cartItems      CartItem[]
  comments       Comment[]
  favorites      Favorite[]
  orderItems     OrderItem[]
  category       Category         @relation(fields: [categoryId], references: [id])
  variants       ProductVariant[]
  analyticsEvents AnalyticsEvent[]

  @@index([categoryId])
  @@index([name])
  @@index([createdAt])
  @@index([price])
}


model User {
  zaloId        String         @id
  name          String
  avatar        String?
  role          String         @default("user")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  birthday      String?
  gender        String?
  phone         String?
  email         String?
  totalSpent     Float          @default(0)
  membershipTier String         @default("Đồng")
  gamificationPoints Float      @default(0)
  height            Float?
  weight            Float?
  footLength        Float?
  clothingSize      String?
  shoeSize          String?
  cartItems     CartItem[]
  comments      Comment[]
  favorites     Favorite[]
  notifications Notification[]
  orders        Order[]
  refreshTokens RefreshToken[]
  addresses     UserAddress[]
  chatMessages  ChatMessage[]
  dailyRewardClaims DailyRewardClaim[]
  pointsHistory PointsHistory[]
  userAchievements UserAchievement[]

  @@index([name])
  @@index([role])
  @@index([createdAt])
  @@index([email])
}

model CartItem {
  id         Int      @id @default(autoincrement())
  zaloUserId String
  productId  Int
  color      String   @default("DEFAULT")
  size       String   @default("DEFAULT")
  quantity   Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [zaloUserId], references: [zaloId], onDelete: Cascade)

  @@unique([zaloUserId, productId, color, size])
}

model ProductVariant {
  id         Int     @id @default(autoincrement())
  productId  Int
  color      String  @default("DEFAULT")
  colorImage String?
  size       String  @default("DEFAULT")
  stock      Int     @default(0)
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, color, size])
}

model Comment {
  id         Int      @id @default(autoincrement())
  productId  Int
  zaloUserId String
  content    String
  rating     Int      @default(5)
  orderId    String?
  images     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [zaloUserId], references: [zaloId], onDelete: Cascade)

  @@unique([orderId, productId])
  @@index([productId])
  @@index([zaloUserId])
  @@index([rating])
  @@index([createdAt])
}

model UserAddress {
  id         Int     @id @default(autoincrement())
  zaloUserId String
  label      String
  phone      String
  street     String
  city       String
  isDefault  Boolean @default(false)
  user       User    @relation(fields: [zaloUserId], references: [zaloId], onDelete: Cascade)
}

model Order {
  id              String      @id
  totalAmount     Float
  status          String      @default("PROCESSING")
  zaloUserId      String?
  createdAt       DateTime    @default(now())
  paymentMethod   String      @default("COD")
  voucherCode     String?
  discountAmount  Float       @default(0)
  shippingAddress String?
  shippingPhone   String?
  shippingName    String?
  trackingNumber  String?
  returnReason      String?
  returnDescription String?
  returnImages      String? // JSON string array of proof images
  estimatedDeliveryDate DateTime?
  shippingMethodCode String?
  user            User?       @relation(fields: [zaloUserId], references: [zaloId])
  items           OrderItem[]

  @@index([zaloUserId])
  @@index([status])
  @@index([createdAt])
  @@index([paymentMethod])
  @@index([estimatedDeliveryDate])
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  quantity  Int
  price     Float
  productId Int
  color     String  @default("DEFAULT")
  size      String  @default("DEFAULT")
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

model Notification {
  id         Int      @id @default(autoincrement())
  zaloUserId String?
  title      String
  content    String
  type       String
  date       String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [zaloUserId], references: [zaloId], onDelete: Cascade)

  @@index([zaloUserId])
  @@index([read])
  @@index([type])
  @@index([date])
  @@index([createdAt])
}

model Favorite {
  id         Int      @id @default(autoincrement())
  zaloUserId String
  productId  Int
  createdAt  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [zaloUserId], references: [zaloId], onDelete: Cascade)

  @@unique([zaloUserId, productId])
  @@index([zaloUserId])
  @@index([productId])
  @@index([createdAt])
}

model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  zaloUserId String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [zaloUserId], references: [zaloId], onDelete: Cascade)

  @@index([token])
  @@index([zaloUserId])
  @@index([expiresAt])
}

model Voucher {
  code        String    @id
  type        String
  value       Float
  minOrderVal Float     @default(0)
  maxDiscount Float?
  stock       Int       @default(999)
  usedCount   Int       @default(0)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([type])
  @@index([stock])
  @@index([expiresAt])
  @@index([createdAt])
}

model Banner {
  id          Int      @id @default(autoincrement())
  imageUrl    String
  tag         String?
  title       String?
  description String?
  cta         String?
  link        String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model SiteSetting {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  label       String
  value       String
  type        String   @default("TEXT")
  group       String   @default("general")
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MenuItem {
  id          Int      @id @default(autoincrement())
  section     String   @default("collections")
  label       String
  targetType  String   @default("CATEGORY")
  target      String?
  description String?
  imageUrl    String?
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StaticPage {
  id           Int      @id @default(autoincrement())
  slug         String   @unique
  title        String
  excerpt      String?
  content      String
  contactPhone String?
  contactEmail String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ShippingMethod {
  id            Int      @id @default(autoincrement())
  code          String   @unique
  name          String
  description   String?
  price         Float    @default(0)
  estimatedDays String?
  sortOrder     Int      @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PaymentMethod {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  name        String
  description String?
  provider    String?
  badge       String?
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChatMessage {
  id         Int      @id @default(autoincrement())
  zaloUserId String
  sender     String   // "USER" or "ADMIN"
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [zaloUserId], references: [zaloId], onDelete: Cascade)

  @@index([zaloUserId])
  @@index([createdAt])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  adminId   String   @default("admin-default")
  action    String
  details   String
  createdAt DateTime @default(now())
}

model AnalyticsEvent {
  id         Int      @id @default(autoincrement())
  zaloUserId String
  eventType  String   // "view", "click", "add_to_cart", "purchase", "search", "filter", "share"
  productId  Int?
  categoryId Int?
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  product    Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([zaloUserId])
  @@index([eventType])
  @@index([productId])
  @@index([createdAt])
}

model DailyRewardClaim {
  id             Int      @id @default(autoincrement())
  zaloUserId     String
  points         Int
  consecutiveDays Int      @default(1)
  claimedAt      DateTime @default(now())

  user           User     @relation(fields: [zaloUserId], references: [zaloId], onDelete: Cascade)

  @@index([zaloUserId])
  @@index([claimedAt])
}

model PointsHistory {
  id         Int      @id @default(autoincrement())
  zaloUserId String
  points     Int
  reason     String
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [zaloUserId], references: [zaloId], onDelete: Cascade)

  @@index([zaloUserId])
  @@index([createdAt])
}

model Achievement {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  icon        String
  condition   String
  createdAt   DateTime @default(now())

  userAchievements UserAchievement[]
}

model UserAchievement {
  id             Int      @id @default(autoincrement())
  zaloUserId     String
  achievementId  Int
  unlockedAt     DateTime @default(now())

  user           User       @relation(fields: [zaloUserId], references: [zaloId], onDelete: Cascade)
  achievement    Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([zaloUserId, achievementId], name: "zaloUserId_achievementId")
  @@index([zaloUserId])
}

model MembershipPrivilege {
  id             Int      @id @default(autoincrement())
  tier           String
  title          String
  description    String
  icon           String
  sortOrder      Int      @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([tier, title])
  @@index([tier])
  @@index([active])
}
